{% render 'reviewos-assets' %}
<div
  class="reviewos"
  data-reviewos
  data-block="ai-summary"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-api-base="{{ block.settings.api_base }}"
  data-page-size="{{ block.settings.page_size }}"
  style="--reviewos-accent: {{ block.settings.accent_color }};"
>
  {% if block.settings.heading != blank %}
    <h3 class="reviewos-block-heading">{{ block.settings.heading }}</h3>
  {% endif %}
</div>

{% schema %}
{
  "name": "AI review summary",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "AI review summary" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#1a1a1a" },
    { "type": "range", "id": "page_size", "label": "Reviews per page", "min": 3, "max": 20, "step": 1, "default": 5 },
    { "type": "text", "id": "api_base", "label": "API base path", "default": "/apps/reviewos" }
  ]
}
{% endschema %}
