{% render 'reviewos-assets' %}
<div
  class="reviewos"
  data-reviewos
  data-block="rating-distribution"
  data-product-id="{{ product.id }}"
  data-product-handle="{{ product.handle }}"
  data-api-base="{{ block.settings.api_base }}"
  style="--reviewos-accent: {{ block.settings.accent_color }};"
>
  {% if block.settings.heading != blank %}
    <h3 class="reviewos-block-heading">{{ block.settings.heading }}</h3>
  {% endif %}
</div>

{% schema %}
{
  "name": "ReviewOS: Rating bars",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rating breakdown" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#1a1a1a" },
    { "type": "text", "id": "api_base", "label": "API base path", "default": "/apps/reviewos" }
  ]
}
{% endschema %}
