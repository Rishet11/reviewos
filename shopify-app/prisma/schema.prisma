// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ---- ReviewOS review core (ported from reviewos/ demo, Phase 2) ----
// JSON-ish fields (attributes, options, pros, cons) stay String and are
// JSON.parse'd in services (drop-in port from the demo). Category-agnostic:
// attribute keys/labels/options are merchant-defined data, never code.
// Multi-tenant: every domain model is scoped by `shop` (Shopify shop domain).
// Uniqueness constraints that would otherwise collide across shops are
// scoped to [shop, ...].

model Product {
  id          String   @id @default(cuid())
  shop        String
  slug        String
  name        String
  category    String
  description String
  price       Int
  imageUrl    String
  shopifyProductId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews          Review[]
  marketplaceStats MarketplaceStat[]
  aiSummaries      AiSummary[]

  @@unique([shop, slug])
  @@index([shop])
}

model Review {
  id                  String    @id @default(cuid())
  shop                String
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  customerName        String
  customerEmail       String?
  rating              Int
  title               String?
  body                String
  helpfulCount        Int       @default(0)
  merchantReply       String?
  merchantRepliedAt   DateTime?
  status              String    @default("approved")
  verifiedBuyer       Boolean   @default(false)
  verifiedMarketplace Boolean   @default(false)
  source              String    @default("website")
  attributes          String
  media               ReviewMedia[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([shop])
  @@index([shop, productId, status])
}

model ReviewMedia {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id])
  type      String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttributeDefinition {
  id              String   @id @default(cuid())
  shop            String
  productCategory String
  key             String
  label           String
  options         String
  display         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, productCategory, key])
  @@index([shop])
}

model MarketplaceSource {
  id        String   @id @default(cuid())
  shop      String
  name      String
  logoUrl   String
  baseUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats MarketplaceStat[]

  @@unique([shop, name])
  @@index([shop])
}

model MarketplaceStat {
  id          String            @id @default(cuid())
  shop        String
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  sourceId    String
  source      MarketplaceSource @relation(fields: [sourceId], references: [id])
  rating      Float
  reviewCount Int
  url         String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([shop, productId, sourceId])
  @@index([shop])
}

model AiSummary {
  id                     String   @id @default(cuid())
  shop                   String
  productId              String
  product                Product  @relation(fields: [productId], references: [id])
  scope                  String
  cohortKey              String   @default("")
  pros                   String
  cons                   String
  summaryText            String
  reviewCountAtGeneration Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([shop, productId, scope, cohortKey])
  @@index([shop])
}

model Settings {
  id        String   @id @default(cuid())
  shop      String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}
