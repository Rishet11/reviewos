// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ---- ReviewOS review core (ported from reviewos/ demo, Phase 2) ----
// JSON-ish fields (attributes, options, pros, cons) stay String and are
// JSON.parse'd in services (drop-in port from the demo). Category-agnostic:
// attribute keys/labels/options are merchant-defined data, never code.
// Multi-tenant: every domain model is scoped by `shop` (Shopify shop domain).
// Uniqueness constraints that would otherwise collide across shops are
// scoped to [shop, ...].

model Product {
  id          String   @id @default(cuid())
  shop        String
  slug        String
  name        String
  category    String
  description String
  price       Int
  imageUrl    String
  shopifyProductId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews          Review[]
  marketplaceStats MarketplaceStat[]
  aiSummaries      AiSummary[]
  reviewRequests   ReviewRequest[]

  @@unique([shop, slug])
  @@index([shop])
}

model Review {
  id                  String    @id @default(cuid())
  shop                String
  productId           String
  product             Product   @relation(fields: [productId], references: [id])
  customerName        String
  customerEmail       String?
  rating              Int
  title               String?
  body                String
  helpfulCount        Int       @default(0)
  merchantReply       String?
  merchantRepliedAt   DateTime?
  status              String    @default("approved")
  verifiedBuyer       Boolean   @default(false)
  verifiedOrderId     String?
  verifiedMarketplace Boolean   @default(false)
  source              String    @default("website")
  attributes          String
  media               ReviewMedia[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ---- Slice 1: CSV review import/export ----
  // importBatchId is a soft reference (no @relation) to ImportBatch.id,
  // matching the OrderCapture/ReviewRequest soft-reference convention above -
  // undoImport prunes reviews by this without any FK cascade to worry about.
  // externalRef is either the source platform's own review id (Judge.me/Loox
  // "id" column) or, when absent, a content hash - either way it's the
  // dedupe key for reimporting the same file/export twice.
  importBatchId       String?
  externalRef         String?

  @@index([shop])
  @@index([shop, productId, status])
  @@index([shop, importBatchId])
  @@index([shop, externalRef])
}

model ReviewMedia {
  id            String   @id @default(cuid())
  reviewId      String
  review        Review   @relation(fields: [reviewId], references: [id])
  type          String
  url           String
  storageKey    String
  mimeType      String
  sizeBytes     Int
  thumbnailUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Tracks R2 objects uploaded via the presign flow before the parent review
// exists. A review is created only after all its media finishes uploading,
// so every presigned upload lands here first; createReview deletes the rows
// it claims. Anything left after `sweepOrphanedMedia`'s cutoff means the
// customer uploaded a file but never finished/submitted the review, so we
// also delete the underlying R2 object.
model PendingReviewMedia {
  id         String   @id @default(cuid())
  shop       String
  storageKey String
  url        String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  @@index([shop])
  @@index([createdAt])
}

model AttributeDefinition {
  id              String   @id @default(cuid())
  shop            String
  productCategory String
  key             String
  label           String
  options         String
  display         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, productCategory, key])
  @@index([shop])
}

model MarketplaceSource {
  id        String   @id @default(cuid())
  shop      String
  name      String
  logoUrl   String
  baseUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stats MarketplaceStat[]

  @@unique([shop, name])
  @@index([shop])
}

model MarketplaceStat {
  id          String            @id @default(cuid())
  shop        String
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  sourceId    String
  source      MarketplaceSource @relation(fields: [sourceId], references: [id])
  rating        Float
  reviewCount   Int
  url           String
  lastCheckedAt DateTime?
  refreshSource String            @default("manual")
  externalRef   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([shop, productId, sourceId])
  @@index([shop])
}

model AiSummary {
  id                     String   @id @default(cuid())
  shop                   String
  productId              String
  product                Product  @relation(fields: [productId], references: [id])
  scope                  String
  cohortKey              String   @default("")
  pros                   String
  cons                   String
  summaryText            String
  reviewCountAtGeneration Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([shop, productId, scope, cohortKey])
  @@index([shop])
}

// ---- Phase 6 Slice B: verified-buyer / order linkage ----
// Webhook-captured order data. `Review.verifiedOrderId` is a deliberate soft
// reference (plain string, no @relation/FK) to OrderCapture.id, matching the
// `MarketplaceStat.url`-as-plain-string convention for cross-cutting external
// references - it lets OrderCapture rows be pruned/GDPR-redacted independently
// with no cascade/constraint ordering to worry about.
model OrderCapture {
  id              String    @id @default(cuid())
  shop            String
  shopifyOrderId  String    // GID, e.g. gid://shopify/Order/6012345678901
  orderName       String?
  customerEmail   String?
  customerPhone   String?   // Slice 5: E.164-normalized, used for the WhatsApp channel only
  customerId      String?
  financialStatus String
  paidAt          DateTime?
  fulfilledAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lineItems OrderLineItem[]

  @@unique([shop, shopifyOrderId])
  @@index([shop])
  @@index([shop, customerEmail])
}

model OrderLineItem {
  id               String       @id @default(cuid())
  orderCaptureId   String
  orderCapture     OrderCapture @relation(fields: [orderCaptureId], references: [id])
  shopifyProductId String?
  shopifyVariantId String?
  title            String
  quantity         Int

  @@index([orderCaptureId])
  @@index([shopifyProductId])
}

// ---- Phase 6 Slice C: post-purchase review-request email ----
// One row per (shop, shopifyOrderId, productId): a line item worth asking
// about. `orderCaptureId` is a soft reference (no @relation/FK), mirroring
// `Review.verifiedOrderId` from Slice B - OrderCapture can be pruned/redacted
// independently of these rows.
model ReviewRequest {
  id                String    @id @default(cuid())
  shop              String
  productId         String
  product           Product   @relation(fields: [productId], references: [id])

  shopifyOrderId    String
  orderCaptureId    String?
  shopifyCustomerId String?
  customerEmail     String
  customerName      String?
  customerPhone     String?   // Slice 5: E.164-normalized, populated when the order webhook carries a phone

  cohort            String    @default("first_time") // "first_time" | "repeat"
  channel           String    @default("email")       // "email" | "whatsapp" (Slice 5)
  deliveredAt       DateTime
  scheduledSendAt   DateTime

  status            String    @default("pending")     // pending | sent | converted | exhausted | suppressed | failed | canceled
  sentCount         Int       @default(0)
  lastSentAt        DateTime?
  failedAttempts    Int       @default(0)
  lastError         String?
  completedReviewId String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([shop, shopifyOrderId, productId])
  @@index([shop])
  @@index([shop, status, scheduledSendAt])
}

model EmailSuppression {
  id        String   @id @default(cuid())
  shop      String
  email     String
  reason    String   @default("unsubscribe") // unsubscribe | customer_redact | bounce
  createdAt DateTime @default(now())

  @@unique([shop, email])
  @@index([shop])
}

// ---- Slice 1: CSV review import/export ----
// One row per uploaded CSV file. Reviews created by a batch carry
// Review.importBatchId, so undo/moderation can act on "everything this file
// created" without needing a join table.
model ImportBatch {
  id            String   @id @default(cuid())
  shop          String
  filename      String
  preset        String
  sourceLabel   String
  status        String   @default("processing") // processing | completed | failed | undone
  totalRows     Int      @default(0)
  importedCount Int      @default(0)
  skippedCount  Int      @default(0)
  errorReport   String   @default("[]") // JSON array of {row, error}
  attestedAt    DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([shop])
}

// ---- Slice 5: WhatsApp review-request channel (merchant-authenticated, BYO Meta Cloud API) ----
// One connection per shop. Secrets (appSecret, accessToken) are stored only in
// their *Enc encrypted form (see app/services/crypto.server.ts) - never plaintext.
model WhatsAppConnection {
  id               String   @id @default(cuid())
  shop             String   @unique
  phoneNumberId    String
  wabaId           String
  appId            String
  appSecretEnc     String
  accessTokenEnc   String
  templateName     String
  templateLanguage String   @default("en")
  templateVarOrder String   // JSON array mapping template body params to canonical vars, e.g. ["customerName","productName","reviewUrl"]
  enabled          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([wabaId])
}

// Channel-scoped suppression list (mirrors EmailSuppression but keyed by
// channel+identifier since WhatsApp opt-outs are by phone number, not email).
model ChannelSuppression {
  id         String   @id @default(cuid())
  shop       String
  channel    String
  identifier String
  reason     String
  createdAt  DateTime @default(now())

  @@unique([shop, channel, identifier])
  @@index([shop])
}

model Settings {
  id        String   @id @default(cuid())
  shop      String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, key])
  @@index([shop])
}
